# Backend
DATABASE_URL="file:./dev.db"
PORT=3001
JWT_SECRET=your-jwt-secret-change-in-production
API_KEY=your-api-key-change-in-production
OPENAI_API_KEY=your-openai-api-key

# Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
